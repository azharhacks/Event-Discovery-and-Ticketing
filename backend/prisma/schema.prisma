// This is our Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum TicketType {
  VIP
  REGULAR
  EARLY_BIRD
}

enum TicketStatus {
  PENDING
  CONFIRMED
  USED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REFUNDED
  FAILED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
}

enum PayoutRecordStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id             String     @id @default(cuid())
  fullName       String
  email          String     @unique
  hashedPassword String
  phone          String?
  role           Role       @default(ATTENDEE)
  status         UserStatus @default(ACTIVE)
  statusReason   String?
  statusChangedAt DateTime?
  verified       Boolean    @default(false)
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())

  events            Event[]
  orders            Order[]
  payoutsReceived   Payout[] @relation("PayoutOrganizer")
  payoutsInitiated  Payout[] @relation("PayoutInitiator")

  @@map("users")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  events      Event[]

  @@map("categories")
}

model Event {
  id           String      @id @default(cuid())
  organiserId  String
  categoryId   String
  title        String
  description  String
  venue        String
  eventDate    DateTime
  eventTime    String
  ticketPrice  Decimal     @db.Decimal(10, 2)
  capacity     Int
  bannerUrl    String?
  status       EventStatus @default(PENDING)
  createdAt    DateTime    @default(now())

  organiser User     @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id])
  tickets   Ticket[]
  payouts   Payout[]

  @@map("events")
}

model Ticket {
  id                Int          @id @default(autoincrement())
  eventId           String
  ticketType        TicketType   @default(REGULAR)
  price             Decimal      @db.Decimal(10, 2)
  quantityAvailable Int
  status            TicketStatus @default(PENDING)
  purchaseDate      DateTime?

  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders  Order[]
  qrCodes QRCode[]

  @@map("tickets")
}

model Order {
  id          String      @id @default(cuid())
  attendeeId  String
  ticketId    Int
  quantity    Int
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  attendee User      @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  ticket   Ticket    @relation(fields: [ticketId], references: [id])
  payment  Payment?

  @@map("orders")
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  mpesaReceiptNumber String?
  amount             Decimal       @db.Decimal(10, 2)
  platformFee        Decimal       @default(0) @db.Decimal(10, 2)
  organizerShare     Decimal       @default(0) @db.Decimal(10, 2)
  status             PaymentStatus @default(PENDING)
  escrowStatus       EscrowStatus  @default(HELD)
  transactionDate    DateTime?
  releasedAt         DateTime?
  refundedAt         DateTime?
  refundReason       String?

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  callback PaymentCallback?

  @@map("payments")
}

model PaymentCallback {
  id                  String   @id @default(cuid())
  paymentId           String   @unique
  merchantRequestId   String
  checkoutRequestId   String
  resultCode          Int
  resultDescription   String
  callbackTimestamp   DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_callbacks")
}

model Payout {
  id                 String             @id @default(cuid())
  organizerId        String
  eventId            String?
  amount             Decimal            @db.Decimal(10, 2)
  status             PayoutRecordStatus @default(PENDING)
  mpesaReceiptNumber String?
  initiatedById      String
  notes              String?
  paidAt             DateTime?
  createdAt          DateTime           @default(now())

  organizer   User   @relation("PayoutOrganizer", fields: [organizerId], references: [id])
  event       Event? @relation(fields: [eventId], references: [id])
  initiatedBy User   @relation("PayoutInitiator", fields: [initiatedById], references: [id])

  @@map("payouts")
}

model QRCode {
  id          String    @id @default(cuid())
  ticketId    Int
  qrToken     String    @unique @default(cuid())
  generatedAt DateTime  @default(now())
  isScanned   Boolean   @default(false)
  scannedAt   DateTime?
  invalidated Boolean   @default(false)

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}
