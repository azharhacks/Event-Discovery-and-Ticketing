// This is our Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // Pooled connection — used by the app at runtime
  directUrl = env("DIRECT_URL")         // Direct connection — used by Prisma migrations
}


// Enums


enum Role {
  ATTENDEE
  ORGANIZER
  ADMIN
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum TicketType {
  VIP
  REGULAR
  EARLY_BIRD
}

enum TicketStatus {
  PENDING
  CONFIRMED
  USED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  REFUNDED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}


// Models


model User {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  hashedPassword String
  phone          String?
  role           Role     @default(ATTENDEE)
  verified       Boolean  @default(false)
  createdAt      DateTime @default(now())

  // Relations
  events  Event[]  // Events organised by this user
  orders  Order[]  // Orders placed by this user as attendee

  @@map("users")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  // Relations
  events Event[]

  @@map("categories")
}

model Event {
  id           String      @id @default(cuid())
  organiserId  String
  categoryId   String
  title        String
  description  String
  venue        String
  eventDate    DateTime
  eventTime    String
  ticketPrice  Decimal     @db.Decimal(10, 2)
  capacity     Int
  bannerUrl    String?
  status       EventStatus @default(PENDING)
  createdAt    DateTime    @default(now())

  // Relations
  organiser User     @relation(fields: [organiserId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id])
  tickets   Ticket[]

  @@map("events")
}

model Ticket {
  id                Int          @id @default(autoincrement())
  eventId           String
  ticketType        TicketType   @default(REGULAR)
  price             Decimal      @db.Decimal(10, 2)
  quantityAvailable Int
  status            TicketStatus @default(PENDING)
  purchaseDate      DateTime?

  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orders  Order[]
  qrCodes QRCode[]

  @@map("tickets")
}

model Order {
  id          String      @id @default(cuid())
  attendeeId  String
  ticketId    Int
  quantity    Int
  totalAmount Decimal     @db.Decimal(10, 2)
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())

  // Relations
  attendee User      @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  ticket   Ticket    @relation(fields: [ticketId], references: [id])
  payment  Payment?

  @@map("orders")
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  mpesaReceiptNumber String?
  amount             Decimal       @db.Decimal(10, 2)
  status             PaymentStatus @default(PENDING)
  transactionDate    DateTime?

  // Relations
  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  callback PaymentCallback?

  @@map("payments")
}

model PaymentCallback {
  id                  String   @id @default(cuid())
  paymentId           String   @unique
  merchantRequestId   String
  checkoutRequestId   String
  resultCode          Int
  resultDescription   String
  callbackTimestamp   DateTime @default(now())

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_callbacks")
}

model QRCode {
  id          String    @id @default(cuid())
  ticketId    Int
  qrToken     String    @unique @default(cuid())
  generatedAt DateTime  @default(now())
  isScanned   Boolean   @default(false)
  scannedAt   DateTime?

  // Relations
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}
